<% content_for :title, "후기 수정 - #{@travel_spot.name}" %>

<div class="max-w-2xl mx-auto px-4 py-12">
  <div class="mb-6">
    <%= link_to "← #{@travel_spot.name}로 돌아가기", travel_spot_path(@travel_spot),
        class: "text-sky-600 text-sm hover:text-sky-700 transition font-medium" %>
  </div>

  <div class="bg-white rounded-2xl shadow-sm p-8">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">✏️ 후기 수정</h1>

    <%= form_with model: [@travel_spot, @review], local: true do |f| %>
      <% if @review.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-5 text-sm text-red-600">
          <% @review.errors.full_messages.each do |msg| %><p>• <%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :title, "후기 제목 *", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.text_field :title, placeholder: "후기 제목을 입력하세요",
              class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300" %>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :rating, "평점 *", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
            <%= f.select :rating,
                options_for_select([["⭐ 1점", 1], ["⭐⭐ 2점", 2], ["⭐⭐⭐ 3점", 3], ["⭐⭐⭐⭐ 4점", 4], ["⭐⭐⭐⭐⭐ 5점", 5]], @review.rating),
                {},
                class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 bg-white" %>
          </div>
          <div>
            <%= f.label :visited_at, "방문일 (선택)", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
            <%= f.date_field :visited_at,
                class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300" %>
          </div>
        </div>

        <div>
          <%= f.label :cover_image, "사진 URL (선택)", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.url_field :cover_image, placeholder: "https://...",
              class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300" %>
        </div>

        <div>
          <%= f.label :content, "후기 내용 *", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.text_area :content, rows: 6, placeholder: "이 여행지에 대한 생생한 후기를 남겨주세요...",
              class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 resize-none" %>
        </div>

        <div class="flex gap-3 pt-2">
          <%= f.submit "💾 수정 저장하기",
              class: "bg-sky-500 text-white px-8 py-3 rounded-xl font-medium hover:bg-sky-600 transition cursor-pointer" %>
          <%= link_to "취소", travel_spot_path(@travel_spot), class: "px-6 py-3 text-sm text-gray-500 hover:text-gray-700 transition" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
