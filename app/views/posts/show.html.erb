<% content_for :title, @post.title %>

<div class="max-w-4xl mx-auto px-4 py-12">

  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to "← 블로그 목록", posts_path, class: "text-sky-600 text-sm hover:text-sky-700 transition font-medium" %>
  </div>

  <!-- Post Header -->
  <article class="bg-white rounded-2xl shadow-sm overflow-hidden mb-8">
    <% if @post.cover_image.present? %>
      <div class="h-72 md:h-96 overflow-hidden">
        <img src="<%= @post.cover_image %>" alt="<%= @post.title %>"
             class="w-full h-full object-cover">
      </div>
    <% else %>
      <div class="h-40 bg-gradient-to-br from-sky-100 to-blue-200 flex items-center justify-center text-6xl">
        📸
      </div>
    <% end %>

    <div class="p-8">
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-2 mb-5">
        <% if @post.category %>
          <span class="bg-sky-100 text-sky-700 text-sm font-medium px-3 py-1 rounded-full">
            <%= @post.category.name %>
          </span>
        <% end %>
        <% @post.tags.each do |tag| %>
          <span class="bg-gray-100 text-gray-500 text-sm px-2.5 py-1 rounded-full">#<%= tag.name %></span>
        <% end %>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4 leading-tight" style="font-family: 'Playfair Display', serif;">
        <%= @post.title %>
      </h1>

      <% if @post.excerpt.present? %>
        <p class="text-gray-500 text-lg mb-6 leading-relaxed border-l-4 border-sky-300 pl-4 italic">
          <%= @post.excerpt %>
        </p>
      <% end %>

      <div class="flex items-center justify-between py-4 border-y border-gray-100 text-sm text-gray-500">
        <div class="flex items-center gap-4">
          <span>✍️ <strong class="text-gray-700"><%= @post.user.email.split("@").first %></strong></span>
          <span>📅 <%= @post.created_at.strftime("%Y년 %m월 %d일") %></span>
        </div>
        <% if user_signed_in? && (current_user == @post.user) %>
          <div class="flex gap-3">
            <%= link_to "✏️ 수정", edit_post_path(@post), class: "text-sky-600 hover:text-sky-700 font-medium transition" %>
            <%= link_to "🗑️ 삭제", post_path(@post), data: { turbo_method: :delete, turbo_confirm: "정말 삭제하시겠어요?" },
                class: "text-red-500 hover:text-red-600 font-medium transition" %>
          </div>
        <% end %>
      </div>

      <!-- Content -->
      <div class="prose prose-sky max-w-none mt-8 text-gray-700 leading-relaxed text-lg">
        <%= simple_format @post.content %>
      </div>
    </div>
  </article>

  <!-- Comments Section -->
  <section class="bg-white rounded-2xl shadow-sm p-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">
      💬 댓글 <span class="text-sky-500 text-xl">(<%= @comments.count %>)</span>
    </h2>

    <!-- Comment List -->
    <% if @comments.any? %>
      <div class="space-y-5 mb-8">
        <% @comments.each do |comment| %>
          <div class="flex gap-4 pb-5 border-b border-gray-100 last:border-0">
            <div class="flex-shrink-0 w-10 h-10 bg-sky-100 rounded-full flex items-center justify-center text-sky-600 font-bold text-sm">
              <%= comment.user.email[0].upcase %>
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1">
                <span class="font-medium text-gray-700 text-sm"><%= comment.user.email.split("@").first %></span>
                <div class="flex items-center gap-3 text-xs text-gray-400">
                  <span><%= comment.created_at.strftime("%Y.%m.%d %H:%M") %></span>
                  <% if user_signed_in? && current_user == comment.user %>
                    <%= link_to "삭제", post_comment_path(@post, comment),
                        data: { turbo_method: :delete, turbo_confirm: "댓글을 삭제할까요?" },
                        class: "text-red-400 hover:text-red-500 transition" %>
                  <% end %>
                </div>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed"><%= comment.content %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8 text-gray-400 mb-6">
        <div class="text-4xl mb-2">💬</div>
        <p class="text-sm">아직 댓글이 없어요. 첫 댓글을 남겨보세요!</p>
      </div>
    <% end %>

    <!-- New Comment Form -->
    <% if user_signed_in? %>
      <div class="border-t border-gray-100 pt-6">
        <h3 class="text-base font-semibold text-gray-700 mb-4">✏️ 댓글 작성</h3>
        <%= form_with model: [@post, @comment], local: true do |f| %>
          <div class="space-y-3">
            <% if @comment.errors.any? %>
              <div class="bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-600">
                <%= @comment.errors.full_messages.first %>
              </div>
            <% end %>
            <%= f.text_area :content, rows: 3, placeholder: "댓글을 입력하세요...",
                class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-transparent resize-none" %>
            <%= f.submit "댓글 등록", class: "bg-sky-500 text-white px-6 py-2.5 rounded-xl text-sm font-medium hover:bg-sky-600 transition cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="border-t border-gray-100 pt-6 text-center text-sm text-gray-500">
        댓글을 달려면 <%= link_to "로그인", new_user_session_path, class: "text-sky-600 font-medium hover:underline" %>이 필요해요.
      </div>
    <% end %>
  </section>

</div>
