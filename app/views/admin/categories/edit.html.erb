<% content_for :title, "카테고리 수정" %>
<div class="max-w-xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "← 목록", admin_categories_path, class: "text-gray-400 hover:text-gray-600 text-sm" %>
    <h1 class="text-2xl font-bold text-gray-800">카테고리 수정</h1>
  </div>
  <div class="bg-white rounded-xl shadow-sm p-7">
    <%= form_with model: [:admin, @category] do |f| %>
      <%= render "form", category: @category, f: f %>
    <% end %>
  </div>
</div>
