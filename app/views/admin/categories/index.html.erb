<% content_for :title, "카테고리 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">🗂️ 카테고리 관리</h1>
  <%= link_to "＋ 새 카테고리", new_admin_category_path,
      class: "bg-sky-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-sky-600 transition" %>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">이름</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">설명</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">포스트 수</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @categories.each do |category| %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-5 py-3.5 font-medium text-gray-800"><%= category.name %></td>
          <td class="px-5 py-3.5 text-gray-500"><%= category.description.presence || "-" %></td>
          <td class="px-5 py-3.5 text-gray-500"><%= category.posts.count %>개</td>
          <td class="px-5 py-3.5 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "수정", edit_admin_category_path(category), class: "text-sky-600 hover:text-sky-700 font-medium" %>
              <%= link_to "삭제", admin_category_path(category),
                  data: { turbo_method: :delete, turbo_confirm: "카테고리를 삭제할까요?" },
                  class: "text-red-500 hover:text-red-600 font-medium" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @categories.empty? %>
        <tr><td colspan="4" class="px-5 py-10 text-center text-gray-400">카테고리가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
