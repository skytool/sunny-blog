<% content_for :title, "태그 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">🏷️ 태그 관리</h1>
  <%= link_to "＋ 새 태그", new_admin_tag_path,
      class: "bg-sky-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-sky-600 transition" %>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">이름</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">사용된 포스트</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @tags.each do |tag| %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-5 py-3.5">
            <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">#<%= tag.name %></span>
          </td>
          <td class="px-5 py-3.5 text-gray-500"><%= tag.posts.count %>개</td>
          <td class="px-5 py-3.5 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "수정", edit_admin_tag_path(tag), class: "text-sky-600 hover:text-sky-700 font-medium" %>
              <%= link_to "삭제", admin_tag_path(tag),
                  data: { turbo_method: :delete, turbo_confirm: "태그를 삭제할까요?" },
                  class: "text-red-500 hover:text-red-600 font-medium" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @tags.empty? %>
        <tr><td colspan="3" class="px-5 py-10 text-center text-gray-400">태그가 없습니다.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
