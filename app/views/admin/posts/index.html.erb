<% content_for :title, "포스트 관리" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">📝 포스트 관리</h1>
  <%= link_to "＋ 새 포스트", new_admin_post_path,
      class: "bg-sky-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-sky-600 transition" %>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">제목</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">카테고리</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">작성자</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">상태</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">날짜</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @posts.each do |post| %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-5 py-3.5 font-medium text-gray-800">
            <%= link_to post.title, post, class: "hover:text-sky-600 transition", target: "_blank" %>
          </td>
          <td class="px-5 py-3.5 text-gray-500"><%= post.category&.name || "-" %></td>
          <td class="px-5 py-3.5 text-gray-500"><%= post.user.email.split("@").first %></td>
          <td class="px-5 py-3.5">
            <% if post.published? %>
              <span class="bg-green-100 text-green-700 text-xs font-medium px-2.5 py-1 rounded-full">공개</span>
            <% else %>
              <span class="bg-gray-100 text-gray-500 text-xs font-medium px-2.5 py-1 rounded-full">비공개</span>
            <% end %>
          </td>
          <td class="px-5 py-3.5 text-gray-400"><%= post.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-5 py-3.5 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "수정", edit_admin_post_path(post), class: "text-sky-600 hover:text-sky-700 font-medium" %>
              <%= link_to "삭제", admin_post_path(post),
                  data: { turbo_method: :delete, turbo_confirm: "포스트를 삭제할까요?" },
                  class: "text-red-500 hover:text-red-600 font-medium" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @posts.empty? %>
        <tr>
          <td colspan="6" class="px-5 py-10 text-center text-gray-400">포스트가 없습니다.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
