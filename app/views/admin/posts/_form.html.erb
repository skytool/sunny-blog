<% if post.errors.any? %>
  <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-sm text-red-600">
    <p class="font-semibold mb-1"><%= post.errors.count %>개의 오류가 있습니다:</p>
    <ul class="list-disc list-inside space-y-0.5">
      <% post.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-5">
  <div>
    <%= f.label :title, "제목 *", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
    <%= f.text_field :title, placeholder: "포스트 제목",
        class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :excerpt, "요약", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
    <%= f.text_field :excerpt, placeholder: "짧은 요약 (선택)",
        class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :content, "내용 *", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
    <%= f.text_area :content, rows: 12, placeholder: "포스트 내용을 입력하세요",
        class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-transparent resize-none" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <%= f.label :category_id, "카테고리", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
      <%= f.collection_select :category_id, @categories, :id, :name,
          { include_blank: "-- 카테고리 없음 --" },
          class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 bg-white" %>
    </div>

    <div>
      <%= f.label :cover_image, "커버 이미지", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
      <%= f.file_field :cover_image, accept: "image/*",
          class: "w-full border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-sky-300 file:mr-3 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-sky-50 file:text-sky-600 hover:file:bg-sky-100" %>
    </div>
  </div>

  <div>
    <p class="block text-sm font-semibold text-gray-700 mb-2">태그</p>
    <div class="flex flex-wrap gap-3">
      <% @tags.each do |tag| %>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <%= f.check_box :tag_ids, { multiple: true, checked: post.tags.include?(tag) }, tag.id, nil %>
          <span class="text-gray-600"><%= tag.name %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-xl">
    <%= f.check_box :published, class: "w-4 h-4 rounded text-sky-600 focus:ring-sky-500" %>
    <%= f.label :published, "공개 발행", class: "text-sm font-medium text-gray-700 cursor-pointer" %>
    <span class="text-xs text-gray-400">체크 해제 시 비공개로 저장됩니다</span>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit post.new_record? ? "✅ 포스트 등록" : "💾 수정 저장",
        class: "bg-sky-500 text-white px-6 py-2.5 rounded-xl font-medium hover:bg-sky-600 transition cursor-pointer" %>
    <%= link_to "취소", admin_posts_path, class: "px-6 py-2.5 text-sm text-gray-500 hover:text-gray-700 transition" %>
  </div>
</div>
