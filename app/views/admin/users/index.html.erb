<% content_for :title, "사용자 관리" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">👥 사용자 관리</h1>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">이메일</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">역할</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">포스트</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">후기</th>
        <th class="text-left px-5 py-3 text-gray-500 font-medium">가입일</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-5 py-3.5 font-medium text-gray-800"><%= user.email %></td>
          <td class="px-5 py-3.5">
            <% if user.admin? %>
              <span class="bg-sky-100 text-sky-700 text-xs font-medium px-2.5 py-1 rounded-full">관리자</span>
            <% else %>
              <span class="bg-gray-100 text-gray-500 text-xs font-medium px-2.5 py-1 rounded-full">일반</span>
            <% end %>
          </td>
          <td class="px-5 py-3.5 text-gray-500"><%= user.posts.count %>개</td>
          <td class="px-5 py-3.5 text-gray-500"><%= user.travel_reviews.count %>개</td>
          <td class="px-5 py-3.5 text-gray-400"><%= user.created_at.strftime("%Y.%m.%d") %></td>
          <td class="px-5 py-3.5 text-right">
            <% unless user == current_user %>
              <%= link_to "삭제", admin_user_path(user),
                  data: { turbo_method: :delete, turbo_confirm: "사용자를 삭제할까요?" },
                  class: "text-red-500 hover:text-red-600 font-medium" %>
            <% else %>
              <span class="text-gray-300 text-xs">현재 계정</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
